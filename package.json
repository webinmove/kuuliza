{
  "name": "@webinmove/kuuliza",
  "version": "1.0.0",
  "description": "Library to expose sequelize queriing abilities in controller",
  "type": "module",
  "directories": {
    "test": "test",
    "dist": "dist"
  },
  "scripts": {
    "build": "rollup --config --bundleConfigAsCjs",
    "format": "semistandard --fix",
    "test:spec": "LOG_LEVEL=fatal mocha",
    "test:lint": "semistandard --verbose | snazzy",
    "test:cover": "c8 npm run test:spec",
    "test": "npm run test:lint && npm run test:cover"
  },
  "exports": {
    "import": "./dist/index.mjs",
    "require": "./dist/index.cjs",
    "types": "./index.d.ts"
  },
  "files": [
    "./dist/index.mjs",
    "./dist/index.cjs",
    "index.d.ts"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/webinmove/kuuliza.git"
  },
  "keywords": [
    "error",
    "errors"
  ],
  "author": "@webinmove",
  "contributors": [
    "Stan Jagiello <stan@imstach.io>",
    "Eric Rodriguez <thewavyx@gmail.com>",
    "Louis Borsu <sat@satprod.net>"
  ],
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/webinmove/kuuliza/issues"
  },
  "homepage": "https://github.com/webinmove/kuuliza#readme",
  "c8": {
    "reporter": [
      "text",
      "lcov"
    ],
    "include": [
      "src/**/*.js"
    ],
    "extension": [
      ".js"
    ],
    "all": true,
    "check-coverage": true,
    "lines": 100,
    "functions": 100,
    "branches": 99,
    "statements": 100
  },
  "semistandard": {
    "globals": [
      "describe",
      "it",
      "before",
      "after",
      "beforeEach",
      "afterEach"
    ],
    "ignore": "dist"
  },
  "devDependencies": {
    "c8": "11.0.0",
    "chai": "4.0.0",
    "mocha": "7.2.0",
    "mocha-standard": "1.0.0",
    "rollup": "4.60.1",
    "semistandard": "17.0.0",
    "sequelize": "6.37.8",
    "snazzy": "7.0.0"
  }
}
