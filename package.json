{
  "name": "@webinmove/kuuliza",
  "version": "1.0.0",
  "description": "Library to expose sequelize queriing abilities in controller",
  "type": "module",
  "directories": {
    "test": "test",
    "dist": "dist"
  },
  "scripts": {
    "build": "rollup --config --bundleConfigAsCjs",
    "test": "LOG_LEVEL=fatal mocha"
  },
  "exports": {
    "import": "./dist/index.mjs",
    "require": "./dist/index.cjs",
    "types": "./index.d.ts"
  },
  "files": [
    "./dist/index.mjs",
    "./dist/index.cjs",
    "index.d.ts"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/webinmove/kuuliza.git"
  },
  "keywords": [
    "error",
    "errors"
  ],
  "author": "@webinmove",
  "contributors": [
    "Stan Jagiello <stan@imstach.io>",
    "Eric Rodriguez <thewavyx@gmail.com>",
    "Louis Borsu <sat@satprod.net>"
  ],
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/webinmove/kuuliza/issues"
  },
  "homepage": "https://github.com/webinmove/kuuliza#readme",
  "semistandard": {
    "globals": [
      "describe",
      "it",
      "before",
      "after"
    ],
    "ignore": "dist"
  },
  "devDependencies": {
    "chai": "4.0.0",
    "mocha": "7.2.0",
    "mocha-standard": "1.0.0",
    "rollup": "4.60.1",
    "semistandard": "17.0.0",
    "sequelize": "6.37.8",
    "snazzy": "7.0.0"
  }
}
